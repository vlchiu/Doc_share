generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   Int               @id @default(autoincrement())
  name                 String
  email                String            @unique
  password             String?
  avatar_url           String?
  role                 Role              @default(USER)
  created_at           DateTime          @default(now())
  is_active            Boolean           @default(true)
  google_id            String?           @unique
  download_reset_at    DateTime?
  email_verify_expires DateTime?
  email_verify_token   String?
  is_email_verified    Boolean           @default(false)
  monthly_downloads    Int               @default(0)
  plan                 Plan              @default(FREE)
  plan_expires_at      DateTime?
  reset_token          String?
  reset_token_expires  DateTime?
  comments             Comment[]
  documents            Document[]
  download_history     DownloadHistory[]
  following            Follow[]          @relation("following")
  followers            Follow[]          @relation("followers")
  notifications        Notification[]
  payments             Payment[]
  ratings              Rating[]
  reports              Report[]
  saved_docs           SavedDocument[]
}

model Category {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  documents   Document[]
}

model Document {
  id               Int               @id @default(autoincrement())
  title            String
  description      String?
  file_url         String
  file_type        String
  view_count       Int               @default(0)
  download_count   Int               @default(0)
  status           Status            @default(PENDING)
  created_at       DateTime          @default(now())
  user_id          Int
  category_id      Int
  doc_type         String            @default("Chung")
  reject_reason    String?
  deleted_at       DateTime?
  comments         Comment[]
  category         Category          @relation(fields: [category_id], references: [id])
  user             User              @relation(fields: [user_id], references: [id])
  download_history DownloadHistory[]
  ratings          Rating[]
  reports          Report[]
  saved_by         SavedDocument[]
}

model Comment {
  id          Int      @id @default(autoincrement())
  content     String
  created_at  DateTime @default(now())
  user_id     Int
  document_id Int
  document    Document @relation(fields: [document_id], references: [id])
  user        User     @relation(fields: [user_id], references: [id])
}

model Notification {
  id         Int      @id @default(autoincrement())
  content    String
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
  user_id    Int
  link       String?
  user       User     @relation(fields: [user_id], references: [id])
}

model SavedDocument {
  user_id     Int
  document_id Int
  saved_at    DateTime @default(now())
  document    Document @relation(fields: [document_id], references: [id])
  user        User     @relation(fields: [user_id], references: [id])

  @@id([user_id, document_id])
}

model Rating {
  user_id     Int
  document_id Int
  score       Int
  created_at  DateTime @default(now())
  document    Document @relation(fields: [document_id], references: [id])
  user        User     @relation(fields: [user_id], references: [id])

  @@id([user_id, document_id])
}

model Report {
  id          Int      @id @default(autoincrement())
  reason      String
  status      String   @default("PENDING")
  created_at  DateTime @default(now())
  user_id     Int
  document_id Int
  action      String?
  admin_note  String?
  document    Document @relation(fields: [document_id], references: [id])
  user        User     @relation(fields: [user_id], references: [id])
}

model DownloadHistory {
  id          Int      @id @default(autoincrement())
  created_at  DateTime @default(now())
  user_id     Int
  document_id Int
  document    Document @relation(fields: [document_id], references: [id])
  user        User     @relation(fields: [user_id], references: [id])
}

model Follow {
  follower_id  Int
  following_id Int
  created_at   DateTime @default(now())
  follower     User     @relation("following", fields: [follower_id], references: [id])
  following    User     @relation("followers", fields: [following_id], references: [id])

  @@id([follower_id, following_id])
}

model Payment {
  id           Int      @id @default(autoincrement())
  order_id     String   @unique
  amount       Int
  plan_months  Int
  status       String   @default("PENDING")
  provider     String
  provider_ref String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  user_id      Int
  user         User     @relation(fields: [user_id], references: [id])
}

enum Plan {
  FREE
  VIP
}

enum Role {
  USER
  ADMIN
}

enum Status {
  PENDING
  APPROVED
  REJECTED
}
